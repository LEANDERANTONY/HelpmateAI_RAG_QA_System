OPENAI_API_KEY=your_openai_api_key

# Backend runtime
HELPMATE_DATA_DIR=./data
HELPMATE_UPLOADS_DIR=./data/uploads
HELPMATE_INDEXES_DIR=./data/indexes
HELPMATE_CACHE_DIR=./data/cache
HELPMATE_CORS_ORIGINS=http://localhost:3000

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=/api
API_REWRITE_TARGET=http://127.0.0.1:8001
