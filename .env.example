OPENAI_API_KEY=your_openai_api_key

# Backend runtime
HELPMATE_DATA_DIR=./data
HELPMATE_UPLOADS_DIR=./data/uploads
HELPMATE_INDEXES_DIR=./data/indexes
HELPMATE_CACHE_DIR=./data/cache
HELPMATE_CORS_ORIGINS=http://localhost:3000
HELPMATE_STATE_STORE_BACKEND=local
HELPMATE_VECTOR_STORE_BACKEND=local
HELPMATE_RERANKER_ENABLED=true
HELPMATE_ROUTER_LLM_ENABLED=true
HELPMATE_EVIDENCE_SELECTOR_ENABLED=false
HELPMATE_WORKSPACE_RETENTION_HOURS=24

# Optional Supabase-backed state
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
HELPMATE_SUPABASE_DOCUMENTS_TABLE=helpmate_documents
HELPMATE_SUPABASE_INDEXES_TABLE=helpmate_indexes
HELPMATE_SUPABASE_ARTIFACTS_TABLE=helpmate_index_artifacts

# Optional hosted Chroma / Chroma Cloud-style HTTP endpoint
HELPMATE_CHROMA_HTTP_HOST=localhost
HELPMATE_CHROMA_HTTP_PORT=8000
HELPMATE_CHROMA_HTTP_SSL=false
HELPMATE_CHROMA_HTTP_TENANT=default_tenant
HELPMATE_CHROMA_HTTP_DATABASE=default_database
HELPMATE_CHROMA_UPSERT_BATCH_SIZE=250
CHROMA_API_KEY=
# Comma-separated headers, for example:
# HELPMATE_CHROMA_HTTP_HEADERS=Authorization=Bearer your_token,X-Custom=value

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=/api
API_REWRITE_TARGET=http://127.0.0.1:8001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
